{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "git": {
    "deploymentEnabled": true
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://solarware-api.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://solarware-api.onrender.com/health"
    }
  ]
}
