# Frontend environment variables for Vercel

# Backend API URL (set this in Vercel environment variables)
# Example for Render: https://solarware-api.onrender.com
# Local development: http://localhost:8000
VITE_API_URL=http://localhost:8000

# Google Maps API Key (optional, for satellite imagery)
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# AdRev runtime layer integration (required to show AdRev layer in Solarware UI)
VITE_ADREV_API_KEY=YOUR_ADREV_API_KEY

# Optional overrides
VITE_ADREV_BASE_URL=https://www.adrevtechnologies.com
VITE_ADREV_ORG_ID=
VITE_ADREV_CAMPAIGN_ID=
